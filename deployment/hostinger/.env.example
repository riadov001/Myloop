# ============================================================
# LocalMarket — Variables d'environnement (Hostinger VPS)
# ============================================================
# Copiez ce fichier en .env et remplissez les valeurs.
# Ne committez JAMAIS le fichier .env dans Git.

# --- Base de données PostgreSQL ---
DATABASE_URL=postgresql://localmarket_user:MOT_DE_PASSE_FORT@localhost:5432/localmarket_db

# --- Serveur API (port interne, Nginx fait le proxy) ---
PORT=8080

# --- Frontend (chemin de base, laisser / pour la racine) ---
BASE_PATH=/

# --- Environnement ---
NODE_ENV=production

# --- Sécurité admin ---
# Changez ce token root immédiatement après le déploiement !
# ADMIN_ROOT_TOKEN=localmarket-root-token-2026   # défini dans adminAuth.ts

# --- Stripe (optionnel) ---
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# --- Email (optionnel) ---
# RESEND_API_KEY=re_...
